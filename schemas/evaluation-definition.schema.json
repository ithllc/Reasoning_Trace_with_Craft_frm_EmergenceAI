{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emergegpt.local/schemas/evaluation-definition.schema.json",
  "title": "EmergeGPT evaluation definition",
  "type": "object",
  "required": ["id", "version", "description", "runner", "metrics", "required_for_promotion"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z][a-z0-9-]+$"},
    "version": {"type": "integer", "minimum": 1},
    "description": {"type": "string", "minLength": 1},
    "runner": {"enum": ["builtin", "prompt-cases", "pairwise", "provider-usage", "lm-eval", "arc-agi", "custom-sandbox"]},
    "task": {"type": "string"},
    "parameters": {"type": "object"},
    "source": {"type": "string"},
    "license": {"type": "string"},
    "applicability": {"type": "array", "items": {"type": "string"}},
    "required_for_promotion": {"type": "boolean"},
    "minimum_samples": {"type": "integer", "minimum": 1},
    "metrics": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "direction", "target", "warning", "rationale"],
        "properties": {
          "id": {"type": "string"},
          "direction": {"enum": ["higher_is_better", "lower_is_better", "must_equal"]},
          "target": {"type": "number"},
          "warning": {"type": "number"},
          "rationale": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
