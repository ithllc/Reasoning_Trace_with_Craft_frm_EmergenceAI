# Never commit the populated .env file.
NEBIUS_API_KEY=
NEBIUS_PROJECT_ID=replace-with-your-project-id
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# A live CRAFT connector requires your own current written authorization.
CRAFT_CONNECTOR_ENABLED=false
CRAFT_AUTHORIZATION_ATTESTED=false
CRAFT_AUTHORIZATION_EXPIRES_AT=
CRAFT_DOCS_MCP_URL=https://docs.emergence.ai/mcp
CRAFT_TENANT_MCP_URL=
CRAFT_PROJECT_ID=replace-with-your-authorized-project-id
CRAFT_OAUTH_CLIENT_ID=
CRAFT_TOOL_SCHEMA_HASH=
CRAFT_READ_PROBE_SUCCEEDED=false
CRAFT_READ_PROBE_AT=

# Verified in this Codex environment.
CODEX_TEACHER_MODEL=gpt-5.6-sol

# Separate dashboard Q&A service. Verify current model pricing before enabling;
# zero/missing prices disable inference. The hard ceiling may not exceed $75.
VOICE_ASSISTANT_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# Reserve $25 of the user's $75 project ceiling for fine-tuning/evaluation.
VOICE_ASSISTANT_MAX_BUDGET_USD=50
VOICE_ASSISTANT_INPUT_USD_PER_MILLION=0.10
VOICE_ASSISTANT_OUTPUT_USD_PER_MILLION=0.30
VOICE_ASSISTANT_MAX_OUTPUT_TOKENS=500
VOICE_ASSISTANT_DASHBOARD_URL=http://127.0.0.1:8765/api/dashboard

# EmergeGPT application/runtime. Replace secrets in production.
EMERGEGPT_ENV=development
EMERGEGPT_DB_PATH=runs/emergegpt.db
EMERGEGPT_BIND_HOST=127.0.0.1
EMERGEGPT_PORT=8765
EMERGEGPT_PUBLIC_ORIGIN=http://127.0.0.1:8765
EMERGEGPT_SESSION_SECRET=replace-in-production
EMERGEGPT_CSRF_SECRET=replace-in-production
EMERGEGPT_EXPERIMENTAL_NEMOCLAW=false

# Notification adapters are disabled until explicitly configured.
EMERGEGPT_EMAIL_ENABLED=false
EMERGEGPT_SLACK_ENABLED=false
EMERGEGPT_TELEGRAM_ENABLED=false
