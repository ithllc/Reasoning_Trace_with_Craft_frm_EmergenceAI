QWEN_BASE_URL=http://127.0.0.1:8080/v1
QWEN_API_KEY=local
QWEN_MODEL=Qwen/Qwen3.5-9B
LLAMA_SERVER_BIN=llama-server
LLAMA_HF_MODEL=bartowski/Qwen_Qwen3.5-9B-GGUF:Q4_K_M
# LLAMA_MODEL_PATH=/absolute/path/to/Qwen3.5-9B-Q4_K_M.gguf
LLAMA_PORT=8080
LLAMA_CONTEXT_SIZE=32768
LLAMA_GPU_LAYERS=auto
SPACETIME_DATABASE=qwen-agent-jobs
SPACETIME_SERVER=local
MAX_AGENT_STEPS=6
TRAINING_DATASET=data/trajectories.jsonl
TRAINING_MODEL=Qwen/Qwen3.5-9B
TRAIN_MAX_LENGTH=4096
TRAIN_EPOCHS=2
TRAIN_LEARNING_RATE=2e-4
TRAIN_BATCH_SIZE=1
TRAIN_GRADIENT_ACCUMULATION=8
LORA_OUTPUT=artifacts/qwen35-agent-lora
# LLAMA_CPP_DIR=/absolute/path/to/llama.cpp
